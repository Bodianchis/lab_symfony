<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}AnimeBash{% endblock %}</title>
        <script src="https://cdn.tailwindcss.com"></script>
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="bg-gray-100 text-gray-900 font-sans">
        <header class="bg-indigo-700 text-white p-4 shadow-md flex justify-between items-center">
    <h1 class="text-2xl font-bold">
        <a href="{{ path('home') }}">AnimeBash</a>
    </h1>
<nav class="space-x-4">
        <a href="{{ path('home') }}" class="hover:text-indigo-200 transition-colors font-medium">Каталог</a>
        <a href="{{ path('feedback') }}" class="hover:text-indigo-200 transition-colors font-medium">Опитування</a>
    </nav>
</header>

        <main class="container mx-auto p-4 mt-4">
            {% for message in app.flashes('success') %}
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4">
                    {{ message }}
                </div>
            {% endfor %}

            {% block content %}{% endblock %}
        </main>
    </body>
</html>