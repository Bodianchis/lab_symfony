{% extends 'base.html.twig' %}

{% block title %}Головна - AnimeBash{% endblock %}

{% block content %}
<div class="max-w-xl mx-auto bg-white p-6 rounded-lg shadow-md">
    <h2 class="text-xl font-semibold mb-4 text-gray-800">Залишити відгук про аніме</h2>
    
    {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
        
        <div>
            {{ form_label(form.title, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(form.title, {'attr': {'class': 'mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border'}}) }}
        </div>

        <div>
            {{ form_label(form.message, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(form.message, {'attr': {'class': 'mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border', 'rows': 4}}) }}
        </div>

        <div class="pt-2">
            {{ form_widget(form.submit, {'attr': {'class': 'w-full bg-indigo-600 text-white font-bold py-2 px-4 rounded hover:bg-indigo-700 transition'}}) }}
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}